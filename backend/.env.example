# ─────────────────────────────────────────────────────────────
#  Backend — Environment Variables
#  Copy this file to .env (never commit .env to git)
#  Set these as environment variables in Railway / Render
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/virtual-learning?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-long-random-secret-string
JWT_EXPIRE=7d

# Frontend origin — used for CORS (NO trailing slash)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:3000

# ── OAuth (optional) ────────────────────────────────────────
# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# ── Email (optional) ────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=noreply@yourdomain.com

# ── File Storage (optional — needed for uploads in production) ─
# If using Cloudinary instead of local /uploads folder:
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
